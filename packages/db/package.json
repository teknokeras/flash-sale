{
    "name": "@flash-sale/db",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "./schema": {
        "import": "./dist/schema.js",
        "types": "./dist/schema.d.ts"
    },
    "scripts": {
        "build": "tsc",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "tsx src/migrate.ts",
        "db:seed": "tsx src/seed.ts"
    },
    "dependencies": {
        "drizzle-orm": "^0.30.0",
        "postgres": "^3.4.0"
    },
    "devDependencies": {
        "drizzle-kit": "^0.21.0",
        "tsx": "^4.7.0",
        "typescript": "^5.4.0",
        "@types/node": "^20.0.0"
    }
}