# ─────────────────────────────────────────────
# .env.local — local Docker Compose environment
# Copy this to .env and fill in values.
# Never commit .env to git.
# ─────────────────────────────────────────────

# Postgres
POSTGRES_USER=flashsale
POSTGRES_PASSWORD=flashsale_secret
POSTGRES_DB=flashsale

# Redis
REDIS_PASSWORD=redis_secret

# JWT — use any long random string locally
JWT_SECRET=local_jwt_secret_change_in_prod

# Admin bootstrap user (matches seed in init.sql)
ADMIN_BOOTSTRAP_EMAIL=admin@local.dev
ADMIN_BOOTSTRAP_PASSWORD=admin_secret
